# =============================================================================
# Octane inter-system HMAC (shared with Engineer hub and sibling spokes)
# =============================================================================
OCTANE_SHARED_SECRET=your-ultra-secure-64-character-hex-secret-here

# =============================================================================
# Supabase (required)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional — npm run check:demo live auth + authenticated RLS (existing user)
DEMO_TEST_EMAIL=
DEMO_TEST_PASSWORD=

# =============================================================================
# OpenAI (required for Nova, Forge, Pixel LLM, and DALL-E mockups)
# =============================================================================
OPENAI_API_KEY=

# =============================================================================
# Etsy OAuth (required for auto-publishing)
# =============================================================================
ETSY_CLIENT_ID=                    # Etsy app "Keystring" (also the OAuth client_id)
ETSY_CLIENT_SECRET=                # Etsy app "Shared secret" — REQUIRED: every Etsy v3 call sends x-api-key as "keystring:shared_secret"
ETSY_WEBHOOK_SECRET=               # verifies incoming personalized-order webhooks
# Revenue/orders analytics (opt-in). Set to "true" ONLY after your Etsy app lists
# the transactions_r scope in the Etsy developer portal, then reconnect Etsy.
# Leave unset for the core connection (drafts + views/favorites analytics);
# revenue/orders are simply skipped until enabled.
# ETSY_ENABLE_TRANSACTIONS_SCOPE=true
# Share & Save trackable shop URL — every link the app shares publicly uses this
# domain so qualifying orders earn reduced Etsy fees. Defaults to the operator's
# share domain when unset (GotchaDayGoods since the 2026-07-03 rebrand).
# ETSY_SHARE_SAVE_URL=https://gotchadaygoods.etsy.com
NEXT_PUBLIC_APP_URL=https://octane-ajax.vercel.app

# =============================================================================
# Lemon Squeezy (optional alternative marketplace)
# =============================================================================
LEMONSQUEEZY_API_KEY=

# =============================================================================
# Gumroad (deprecated — legacy manual URL support only)
# =============================================================================
GUMROAD_ACCESS_TOKEN=

# =============================================================================
# Other adapters (server-side only — no NEXT_PUBLIC_ prefix)
# =============================================================================

# Printify — print-on-demand products
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=

# TikTok — short-form posts (OAuth + Content Posting API)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=

# Social publishing (Ayrshare) — ONE key posts to all linked networks.
# Sign up at ayrshare.com, link your socials in their dashboard, add the key here.
# Enables the "Publish now" button on Pixel's promo packages (TikTok queue panel).
AYRSHARE_API_KEY=
# SOCIAL_PLATFORMS=instagram,facebook,pinterest   # where posts go (comma-separated)
# AYRSHARE_API_URL=https://api.ayrshare.com/api/post

# Image generation (set provider to "openai" in prod for live gpt-image-1)
IMAGE_GENERATOR_PROVIDER=demo
IMAGE_GENERATOR_API_KEY=
# IMAGE_GENERATOR_MODEL=gpt-image-1
# IMAGE_GENERATION_TIMEOUT_MS=45000
# PRINTIFY_TIMEOUT_MS=90000

# =============================================================================
# Multi-model router (optional — each falls back to OpenAI when its key is absent)
# =============================================================================
ANTHROPIC_API_KEY=                 # Nova ideation + War Room strategy (Claude)
GEMINI_API_KEY=                    # Pixel marketing copy (Gemini)
# Per-task overrides (TASK = IDEATION | STRATEGY | MARKETING | SCORING | LISTING):
#   LLM_IDEATION_MODEL=claude-sonnet-4-6
#   LLM_MARKETING_MODEL=gemini-2.0-flash
#   LLM_FALLBACK_MODEL=gpt-4o-mini
# WARROOM_MODEL=gpt-4o-mini
# Bias which products Forge makes. Catalog keys or plain words, comma-separated.
# Leave unset for an auto mix (apparel/mugs for slogans, posters for wall-art).
# FORGE_PRODUCT_FOCUS=TEE_UNISEX,SWEATSHIRT_CREWNECK,MUG_11OZ

# =============================================================================
# Nova market research (optional)
# =============================================================================
SERPAPI_API_KEY=                   # Google Trends demand signals
YOUTUBE_API_KEY=                   # YouTube buzz signals

# =============================================================================
# Automation / cron
# =============================================================================
CRON_SECRET=                       # Bearer token Vercel Cron sends to /api/cron/*
OPERATOR_EMAIL=                    # operator account email (cron resolves the user)
